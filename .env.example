# Copy this file to .env and fill in your key. Never commit the real .env.
# (.env.example itself should never contain a real secret — it's the
# template, and unlike .env it isn't gitignored.)

# Which LLM backs the orchestrator: "anthropic" (default, what Stage 2 was
# spec'd against) or "deepseek" (OpenAI-compatible API). Switching requires
# the matching key below to be set.
LLM_PROVIDER=anthropic

ANTHROPIC_API_KEY=sk-ant-your-key-here
MODEL_NAME=claude-sonnet-4-6

DEEPSEEK_API_KEY=sk-your-deepseek-key-here
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Optional overrides (defaults shown):
MAX_TOKENS=2048
MAX_TOOL_ITERATIONS=8
