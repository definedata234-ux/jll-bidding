            "description": "Specific FM categories to retrieve (pantry, stationery, washroom, electrical, plumbing, general_ops). Omit for the full catalog."
          }
        },
        "required": [
          "headcount"
        ],
        "type": "object"
      }
    },
    {
      "name": "save_draft_artifact",
      "description": "Persist a generated draft (bid proposal, negotiation brief, FM bundle recommendation, or FM upsell pitch) to the opportunity record for human review. This ONLY saves a draft \u2014 it never sends, emails, or finalizes anything to a client. Always follow with request_human_approval before treating the artifact as client-ready.",
      "input_schema": {
        "properties": {
          "opportunity_id": {
            "type": "string"
          },
          "artifact_type": {
            "enum": [
              "bid_proposal",
              "negotiation_brief",
              "fm_bundle_recommendation",
              "fm_upsell_pitch"
            ],
            "type": "string"
          },
          "content": {
            "description": "The full drafted content (markdown or plain text).",
            "type": "string"
          },
          "version": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "default": null
          },
          "status": {
            "default": "draft",
            "description": "Draft status. Never set directly to an approved/sent state via this tool.",
            "type": "string"
          }
        },
        "required": [
          "opportunity_id",
          "artifact_type",
          "content"
        ],
        "type": "object"
      }
    },
    {
      "name": "request_human_approval",
      "description": "Notify a human JLL bid manager/account manager that an artifact (proposal, negotiation brief, pricing change, FM pitch) is ready and requires review/approval before anything is sent to the client. This is the mandatory gate before any client-facing action \u2014 call it before treating any artifact as final.",
      "input_schema": {
        "properties": {
          "opportunity_id": {
            "type": "string"
          },
          "artifact_type": {
            "description": "What kind of artifact or decision needs approval.",
            "type": "string"
          },
          "summary": {
            "description": "Concise summary of what's being requested for approval and why.",
            "type": "string"
          },
          "urgency": {
            "default": "normal",
            "description": "'normal' or 'high' if there's a client deadline.",
            "type": "string"
          }
        },
        "required": [
          "opportunity_id",
          "artifact_type",
          "summary"
        ],
        "type": "object"
      }
    },
    {
      "name": "log_pipeline_event",
      "description": "Record a pipeline/event log entry for reporting (win rate, time-to-proposal, FM attach rate, cycle time). Call at every stage transition, and always at outcome determination (won/lost) and at FM upsell pitch/attach events.",
      "input_schema": {
        "properties": {
          "opportunity_id": {
            "type": "string"
          },
          "stage": {
            "enum": [
              "INTAKE",
              "SHORTLISTING",
              "COMPARISON",
              "PROPOSAL_DRAFTING",
              "FM_BUNDLING",
              "NEGOTIATION",
              "OUTCOME_PENDING",
              "WON_CLOSEOUT",
              "LOST_FM_UPSELL",
              "LOGGED"
            ],
            "type": "string"
          },
          "event": {
            "description": "Short description of what happened.",
            "type": "string"
          },
          "outcome": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "description": "'won', 'lost', or 'pending' \u2014 set only for outcome-determination events."
          },
          "notes": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null
          }
        },
        "required": [
          "opportunity_id",
          "stage",
          "event"
        ],
        "type": "object"
      }
    }
  ]
}
